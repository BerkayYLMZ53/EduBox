rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Profile
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 100 &&
             data.successScore is number &&
             data.level is number &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100)) &&
             (data.department == null || (data.department is string && data.department.size() <= 100)) &&
             (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000000));
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Security: do not allow listing users
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == request.auth.uid;
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Prevent spoofing immutable fields
        incoming().uid == existing().uid &&
        incoming().email == existing().email &&
        incoming().successScore == existing().successScore &&
        incoming().level == existing().level
      );
    }

    // Rewards (System Created)
    match /rewards/{rewardId} {
      allow read: if isSignedIn();
      allow write: if false; // System only
    }

    // Tasks (System Created)
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if false; // System only
    }

    // User Task Progress
    function isValidUserTask(data) {
      return data.userId == request.auth.uid &&
             data.taskId is string &&
             data.status in ['in_progress', 'completed'];
    }

    match /user_tasks/{userTaskId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId); 
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidUserTask(incoming());
      allow update: if isOwner(existing().userId) && isValidUserTask(incoming()) && incoming().userId == existing().userId;
    }

    // Community Notes
    function isValidNote(data) {
      return data.authorId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 10000;
    }

    match /notes/{noteId} {
      allow list: if isSignedIn(); 
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidNote(incoming());
      allow update: if (isOwner(existing().authorId) && isValidNote(incoming()) && incoming().authorId == existing().authorId) ||
                    (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['upvotes']));
      allow delete: if isOwner(existing().authorId);
    }

    // Reward Claims
    match /reward_claims/{claimId} {
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }

    // Feedback
    function isValidFeedback(data) {
      return data.userId == request.auth.uid &&
             data.type in ['suggestion', 'bug', 'general'] &&
             data.message is string && data.message.size() <= 5000;
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn() && isValidFeedback(incoming());
    }
  }
}
